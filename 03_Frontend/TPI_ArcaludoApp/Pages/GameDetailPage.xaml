<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TPI_ArcaludoApp.ViewModels"
             xmlns:models="clr-namespace:TPI_ArcaludoApp.Models"
             x:Class="TPI_ArcaludoApp.Pages.GameDetailPage"
             BackgroundColor="#000000"
             Shell.NavBarIsVisible="False">

    <ContentPage.BindingContext>
        <vm:GameDetailViewModel />
    </ContentPage.BindingContext>

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- HEADER — padding top réduit (0 au lieu de 44) -->
            <Grid BackgroundColor="#4A4A6A"
                  Padding="12,8,16,12"
                  ColumnDefinitions="Auto,*,Auto">
                <Button Grid.Column="0"
                        Text="←" Command="{Binding GoBackCommand}"
                        BackgroundColor="Transparent" TextColor="White"
                        FontSize="22" WidthRequest="44" HeightRequest="44" Padding="0" />
                <Label Grid.Column="1"
                       Text="{Binding CurrentGame.Title}"
                       TextColor="White" FontSize="16" FontAttributes="Bold"
                       VerticalOptions="Center" HorizontalOptions="Center"
                       LineBreakMode="TailTruncation" />
                <!-- Metacritic dans le header -->
                <Label Grid.Column="2"
                       Text="{Binding CurrentGame.MetacriticDisplay}"
                       TextColor="#F5C42B" FontSize="14" FontAttributes="Bold"
                       VerticalOptions="Center" />
            </Grid>

            <!-- COVER -->
            <Image Source="{Binding CurrentGame.CoverImageSource}"
                   HeightRequest="220" Aspect="AspectFill"
                   BackgroundColor="#1a1a1a" />

            <VerticalStackLayout Padding="16" Spacing="0">

                <!-- PUBLISHER / DEVELOPER (sans l'année) -->
                <Grid ColumnDefinitions="*,*" Margin="0,12,0,8">
                    <HorizontalStackLayout Grid.Column="0" Spacing="4">
                        <Label Text="🏢" TextColor="#aaa" FontSize="12" VerticalOptions="Center" />
                        <Label Text="{Binding CurrentGame.Publisher}"
                               TextColor="#aaa" FontSize="12" LineBreakMode="TailTruncation" />
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Grid.Column="1" Spacing="4">
                        <Label Text="👤" TextColor="#aaa" FontSize="12" VerticalOptions="Center" />
                        <Label Text="{Binding CurrentGame.Developer}"
                               TextColor="#aaa" FontSize="12" LineBreakMode="TailTruncation" />
                    </HorizontalStackLayout>
                </Grid>

                <!-- GENRE + ANNÉE sur la même ligne -->
                <HorizontalStackLayout Spacing="16" Margin="0,0,0,16">
                    <HorizontalStackLayout Spacing="4">
                        <Label Text="🧩" TextColor="#aaa" FontSize="12" VerticalOptions="Center" />
                        <Label Text="{Binding CurrentGame.Genre}" TextColor="#aaa" FontSize="12" />
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="4">
                        <Label Text="📅" TextColor="#aaa" FontSize="12" VerticalOptions="Center" />
                        <Label Text="{Binding CurrentGame.ReleaseYear}" TextColor="#aaa" FontSize="12" />
                    </HorizontalStackLayout>
                </HorizontalStackLayout>

                <!-- ── STATUT ── -->
                <Grid ColumnDefinitions="*,Auto,*" Margin="0,0,0,12">
                    <BoxView Grid.Column="0" HeightRequest="1" BackgroundColor="#333" VerticalOptions="Center" />
                    <Label Grid.Column="1" Text="STATUT" TextColor="White"
                           FontAttributes="Bold" FontSize="13" Margin="10,0" />
                    <BoxView Grid.Column="2" HeightRequest="1" BackgroundColor="#333" VerticalOptions="Center" />
                </Grid>

                <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="8" Margin="0,0,0,20">
                    <Button Grid.Column="0" Text="Acquis"
                            Command="{Binding SelectStatusCommand}"
                            CommandParameter="acquis"
                            BackgroundColor="{Binding AcquisColor}"
                            TextColor="White" FontSize="12"
                            CornerRadius="8" HeightRequest="44" Padding="4,0" />
                    <Button Grid.Column="1" Text="En cours"
                            Command="{Binding SelectStatusCommand}"
                            CommandParameter="playing"
                            BackgroundColor="{Binding PlayingColor}"
                            TextColor="White" FontSize="12"
                            CornerRadius="8" HeightRequest="44" Padding="4,0" />
                    <Button Grid.Column="2" Text="Terminé"
                            Command="{Binding SelectStatusCommand}"
                            CommandParameter="termine"
                            BackgroundColor="{Binding TermineColor}"
                            TextColor="White" FontSize="12"
                            CornerRadius="8" HeightRequest="44" Padding="4,0" />
                    <Button Grid.Column="3" Text="Souhait"
                            Command="{Binding SelectStatusCommand}"
                            CommandParameter="wishlist"
                            BackgroundColor="{Binding WishlistColor}"
                            TextColor="White" FontSize="12"
                            CornerRadius="8" HeightRequest="44" Padding="4,0" />
                </Grid>

                <!-- ── MES PLATEFORMES ── -->
                <Grid ColumnDefinitions="*,Auto,*" Margin="0,0,0,12">
                    <BoxView Grid.Column="0" HeightRequest="1" BackgroundColor="#333" VerticalOptions="Center" />
                    <Label Grid.Column="1" Text="MES PLATEFORMES" TextColor="White"
                           FontAttributes="Bold" FontSize="13" Margin="10,0" />
                    <BoxView Grid.Column="2" HeightRequest="1" BackgroundColor="#333" VerticalOptions="Center" />
                </Grid>

                <FlexLayout BindableLayout.ItemsSource="{Binding Platforms}"
                            Wrap="Wrap"
                            Direction="Row"
                            JustifyContent="Start"
                            AlignItems="Start"
                            Margin="0,0,0,20">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="models:PlatformItem">
                            <Border BackgroundColor="{Binding ChipBackground}"
                                    StrokeShape="RoundRectangle 100"
                                    Stroke="Transparent"
                                    Padding="14,8"
                                    Margin="0,0,8,8">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:GameDetailViewModel}}, Path=TogglePlatformCommand}"
                                        CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <Label Text="{Binding Name}"
                                       TextColor="{Binding ChipTextColor}"
                                       FontSize="13"
                                       FontAttributes="Bold" />
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </FlexLayout>

                <!-- ── MES DONNÉES ── -->
                <Grid ColumnDefinitions="*,Auto,*" Margin="0,0,0,12">
                    <BoxView Grid.Column="0" HeightRequest="1" BackgroundColor="#333" VerticalOptions="Center" />
                    <Label Grid.Column="1" Text="MES DONNÉES" TextColor="White"
                           FontAttributes="Bold" FontSize="13" Margin="10,0" />
                    <BoxView Grid.Column="2" HeightRequest="1" BackgroundColor="#333" VerticalOptions="Center" />
                </Grid>

                <!-- TEMPS DE JEU -->
                <Border BackgroundColor="#0a0a0a"
                        Stroke="#2a2a2a"
                        StrokeShape="RoundRectangle 12"
                        Padding="16,12"
                        Margin="0,0,0,10">
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                        <Label Grid.Column="0" Text="⏱" FontSize="18" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="Temps de jeu"
                               TextColor="White" FontSize="14"
                               FontAttributes="Bold" VerticalOptions="Center"
                               Margin="10,0" />
                        <Entry Grid.Column="2"
                               Text="{Binding PlaytimeText}"
                               Keyboard="Numeric"
                               TextColor="#3A7AFE"
                               BackgroundColor="Transparent"
                               FontSize="16" FontAttributes="Bold"
                               HorizontalTextAlignment="End"
                               WidthRequest="60"
                               VerticalOptions="Center"
                               Placeholder="0"
                               PlaceholderColor="#555" />
                        <Label Grid.Column="3" Text="h"
                               TextColor="#3A7AFE" FontSize="14"
                               VerticalOptions="Center" Margin="4,0,0,0" />
                    </Grid>
                </Border>

                <!-- MA NOTE -->
                <Border BackgroundColor="#0a0a0a"
                        Stroke="#2a2a2a"
                        StrokeShape="RoundRectangle 12"
                        Padding="16,12"
                        Margin="0,0,0,10">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Label Grid.Column="0" Text="★" TextColor="#F5C42B"
                               FontSize="18" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="Ma note"
                               TextColor="White" FontSize="14"
                               FontAttributes="Bold" VerticalOptions="Center"
                               Margin="10,0" />
                        <HorizontalStackLayout Grid.Column="2" Spacing="4" VerticalOptions="Center">
                            <Entry Text="{Binding RatingText}"
                                   Keyboard="Numeric"
                                   TextColor="#3A7AFE"
                                   BackgroundColor="Transparent"
                                   FontSize="16" FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"
                                   WidthRequest="44"
                                   VerticalOptions="Center"
                                   Placeholder="0"
                                   PlaceholderColor="#555" />
                            <Label Text="/ 5"
                                   TextColor="#aaa" FontSize="14"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Grid>
                </Border>

                <!-- COMMENTAIRE -->
                <Border BackgroundColor="#0a0a0a"
                        Stroke="#2a2a2a"
                        StrokeShape="RoundRectangle 12"
                        Padding="14,10"
                        Margin="0,0,0,24">
                    <Editor Placeholder="Commentaire..."
                            PlaceholderColor="#666"
                            TextColor="White"
                            BackgroundColor="Transparent"
                            Text="{Binding Comment}"
                            AutoSize="TextChanges"
                            MinimumHeightRequest="80" />
                </Border>

                <!-- BOUTON ENREGISTRER -->
                <Button Text="💾 Enregistrer"
                        Command="{Binding SaveCommand}"
                        BackgroundColor="#3A7AFE"
                        TextColor="White"
                        FontAttributes="Bold"
                        FontSize="15"
                        CornerRadius="100"
                        HeightRequest="52"
                        Margin="0,0,0,12" />

                <!-- BOUTON RETIRER (visible seulement si jeu dans la collection) -->
                <Button Text="🗑 Retirer de ma collection"
                        Command="{Binding RemoveFromCollectionCommand}"
                        BackgroundColor="Transparent"
                        TextColor="#E74C3C"
                        BorderColor="#E74C3C"
                        BorderWidth="1.5"
                        FontSize="14"
                        CornerRadius="100"
                        HeightRequest="48"
                        Margin="0,0,0,32" />

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>