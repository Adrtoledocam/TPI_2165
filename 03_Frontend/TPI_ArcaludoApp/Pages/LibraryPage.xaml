<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TPI_ArcaludoApp.ViewModels"
             xmlns:models="clr-namespace:TPI_ArcaludoApp.Models"
             x:Class="TPI_ArcaludoApp.Pages.LibraryPage"
             BackgroundColor="#000000"
             Title="Bibliothèque">

    <ContentPage.BindingContext>
        <vm:LibraryViewModel />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Barre de recherche -->
        <Border Grid.Row="0"
                BackgroundColor="#1a1a1a"
                Stroke="Transparent"
                StrokeShape="RoundRectangle 100"
                Margin="16,12,16,8">
            <HorizontalStackLayout Padding="14,0" Spacing="8">
                <Label Text="🔍" FontSize="16" VerticalOptions="Center" />
                <Entry Placeholder="Rechercher un jeu..."
                       PlaceholderColor="#666"
                       TextColor="White"
                       BackgroundColor="Transparent"
                       Text="{Binding SearchText}"
                       ReturnCommand="{Binding SearchCommand}"
                       HorizontalOptions="FillAndExpand" />
            </HorizontalStackLayout>
        </Border>

        <!-- Filtres et Tri -->
        <ScrollView Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalScrollBarVisibility="Never"
                    Margin="16,0,16,8">
            <HorizontalStackLayout Spacing="8">
                <Button Text="+Notés"
                        Command="{Binding SortCommand}"
                        CommandParameter="notes"
                        BackgroundColor="{Binding NotesButtonColor}"
                        TextColor="White" FontSize="13"
                        CornerRadius="100" Padding="16,8" HeightRequest="36" />
                <Button Text="À venir"
                        Command="{Binding SortCommand}"
                        CommandParameter="avenir"
                        BackgroundColor="{Binding AvenirButtonColor}"
                        TextColor="White" FontSize="13"
                        CornerRadius="100" Padding="16,8" HeightRequest="36" />
                <Button Text="A - Z"
                        Command="{Binding SortCommand}"
                        CommandParameter="az"
                        BackgroundColor="{Binding AZButtonColor}"
                        TextColor="White" FontSize="13"
                        CornerRadius="100" Padding="16,8" HeightRequest="36" />
                <Button Text="Z - A"
                        Command="{Binding SortCommand}"
                        CommandParameter="za"
                        BackgroundColor="{Binding ZAButtonColor}"
                        TextColor="White" FontSize="13"
                        CornerRadius="100" Padding="16,8" HeightRequest="36" />
            </HorizontalStackLayout>
        </ScrollView>

        <!-- Liste -->
        <CollectionView Grid.Row="2" ItemsSource="{Binding Games}">

            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center"
                                     HorizontalOptions="Center"
                                     Spacing="12" Padding="32">
                    <Label Text="🔍" FontSize="48" HorizontalOptions="Center" />
                    <Label Text="Aucun jeu trouvé"
                           TextColor="#666" FontSize="15"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Game">
                    <Border BackgroundColor="#0a0a0a"
                            Stroke="#2a2a2a"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 14"
                            Margin="16,0,16,10">
                        <Grid ColumnDefinitions="120,*" Padding="0">

                            <!-- Img -->
                            <Image Grid.Column="0"
                                   Source="{Binding CoverUrl}"
                                   HeightRequest="130"
                                   WidthRequest="120"
                                   Aspect="AspectFill"
                                   BackgroundColor="#1a1a1a" />

                            <!-- INFOS -->
                            <VerticalStackLayout Grid.Column="1"
                                                 Padding="12,10" Spacing="4">

                                <Label Text="{Binding Title}"
                                       TextColor="White" FontSize="15"
                                       FontAttributes="Bold"
                                       LineBreakMode="TailTruncation" />

                                <Label Text="{Binding MetacriticDisplay}"
                                       TextColor="#F5C42B" FontSize="13"
                                       FontAttributes="Bold" />

                                <Label Text="{Binding Genre}"
                                       TextColor="#bbb" FontSize="12" />

                                <Label Text="{Binding ReleaseYear}"
                                       TextColor="#777" FontSize="11" />

                                <!-- Déjà dans la collection -->
                                <Border IsVisible="{Binding InCollection}"
                                        BackgroundColor="Transparent"
                                        Stroke="#76E16C"
                                        StrokeShape="RoundRectangle 100"
                                        Padding="10,5"
                                        HorizontalOptions="Start"
                                        Margin="0,6,0,0">
                                    <Label Text="✓ Dans ma collection"
                                           TextColor="#76E16C"
                                           FontSize="11" FontAttributes="Bold" />
                                </Border>

                                <!-- Pas encore dans la collection -->
                                <HorizontalStackLayout IsVisible="{Binding NotInCollection}"
                                                       Spacing="8" Margin="0,6,0,0">
                                    <Button Text="+ Ajouter"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:LibraryViewModel}}, Path=GoToDetailCommand}"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="#3A7AFE"
                                            TextColor="White" FontSize="12"
                                            CornerRadius="100"
                                            Padding="12,0" HeightRequest="34" />

                                    <Button Text="♥"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:LibraryViewModel}}, Path=AddToWishlistCommand}"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="#2a2a2a"
                                            TextColor="#FF6B9D" FontSize="16"
                                            CornerRadius="100"
                                            WidthRequest="36" HeightRequest="34"
                                            Padding="0" />
                                </HorizontalStackLayout>

                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>
    </Grid>
</ContentPage>